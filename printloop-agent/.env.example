# ── PrintLoop Agent — config (copy to .env, edit, never commit) ─────────
#
# This file is the ONLY config the agent reads. Everything else is hard-
# coded into agent.ts so a sysadmin can copy this once and forget it.

# ─ Cloud backend ─────────────────────────────────────────────────────
# Where the cloud-hosted PrintLoop backend lives. The agent polls
# /api/agent/jobs/ready on this base URL.
PRINTLOOP_BASE_URL=https://printloop-production.up.railway.app

# The kiosk's API key — same X-Kiosk-Key the in-browser kiosk panel uses.
# Generated by an admin from the Admin → Kiosks tab. Treat like a password.
KIOSK_API_KEY=replace-with-real-kiosk-key

# ─ Local printer ─────────────────────────────────────────────────────
# IP address of the printer on this kiosk's LAN. The agent opens the
# socket; the cloud never sees this address.
PRINTER_IP=192.168.0.111

# 'ipp' (default, standard IPP Print-Job over HTTP) or 'raw9100' (TCP
# raw socket + PJL — needed for Sharp MX-series and other printers
# whose IPP filter silently drops anonymous jobs).
PRINTER_TRANSPORT=raw9100

# IPP port (only used when PRINTER_TRANSPORT=ipp). 631 is the IANA
# IPP/IPPS port — almost every networked printer.
PRINTER_PORT=631

# IPP path. Sharp MX-series = /ipp/lp ; CUPS queues = /printers/<name> ;
# IPP-Everywhere / AirPrint = /ipp/print (default).
IPP_PATH=/ipp/print

# IPP protocol version. Default 2.0 (IPP-Everywhere). Set to 1.1 for
# Sharp MX-series and other older / vendor-quirky firmwares.
IPP_VERSION=1.1

# Raw-socket port (only used when PRINTER_TRANSPORT=raw9100). 9100 is
# the de facto standard ("JetDirect" / "AppSocket") port.
PRINTER_RAW_PORT=9100

# ─ Tuning ────────────────────────────────────────────────────────────
# How often to poll the cloud for new jobs (milliseconds). 4 seconds
# feels instant to the customer at the kiosk; lower if you want.
POLL_INTERVAL_MS=4000
