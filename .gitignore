# ── Dependencies & build artefacts ────────────────────────────────────
node_modules/
dist/
build/
*.tsbuildinfo

# ── Local secrets (never commit) ─────────────────────────────────────
.env
.env.local
.env.*.local

# ── Logs ──────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── OS / editor ──────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
Thumbs.db

# ── Backend runtime data ─────────────────────────────────────────────
# The SQLite DB is created automatically by the seed on first boot;
# committing it would carry test users + jobs into every clone and
# produce noisy binary diffs.
01-backend/data/printloop.sqlite
01-backend/data/printloop.sqlite-*
# Uploaded customer documents — real user content, never commit.
01-backend/data/uploads/
# Test artefacts captured by the virtual printer.
01-backend/data/printed/
# Legacy mock JSON store used by the devApi catch-all router.
01-backend/data/dev-store.json

# ── Archives / large binaries ────────────────────────────────────────
*.tar
*.zip
