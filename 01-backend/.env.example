# ─────────────────────────────────────────────────────────
# PrintLoop API — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
APP_VERSION=1.0.0
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://printloop.ng

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/printloop
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=printloop
DB_PASSWORD=changeme
DB_NAME=printloop

# Redis (used for caching + BullMQ + rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Paystack (payments)
# WEBHOOK_SECRET is used to verify HMAC-SHA512 of the raw webhook body.
# If unset, the SECRET_KEY is used as the HMAC key (Paystack's default).
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=

# Email (SMTP - use SendGrid, Mailgun, AWS SES etc.)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=PrintLoop <noreply@printloop.ng>

# SMS (Termii - popular in Nigeria)
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=PrintLoop

# Stripe (optional - for international payments)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Firebase (optional - for push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
